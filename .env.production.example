// This is a sample environment file for production deployment
// DO NOT COMMIT THIS FILE - Use Vercel's environment variables dashboard instead

// ============================================
// Database (From Supabase)
// ============================================
// Get this from Supabase -> Settings -> Database -> Connection pooling
// Use the Connection Pooling URL (not the regular connection URL)
DATABASE_URL="postgresql://postgres.[PROJECT_ID]:PASSWORD@db.[PROJECT_ID].supabase.co:6543/postgres?pgbouncer=true&schema=public"

// ============================================
// Application
// ============================================
NODE_ENV=production
PORT=3000
APP_NAME=upasna-jyoti-api

// ============================================
// CORS (UPDATE WITH YOUR DOMAIN)
// ============================================
// Add both your Vercel URL and custom domain if you have one
ALLOWED_ORIGINS="https://inner-light-luxury.vercel.app,https://yourdomain.com"

// ============================================
// Authentication & Security
// ============================================
// Generate JWT secret: openssl rand -base64 32
JWT_SECRET="your-generated-jwt-secret-min-32-chars"
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

// ============================================
// Frontend URLs
// ============================================
// Update with your frontend URL
FRONTEND_URL="https://inner-light-luxury.vercel.app"

// ============================================
// Google OAuth (If using)
// ============================================
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="https://upasna-jyoti-api.vercel.app/auth/google/callback"

// ============================================
// Payment Providers
// ============================================
// Razorpay
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

// Stripe (if using)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

// ============================================
// Rate Limiting
// ============================================
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX_REQUESTS=100

// ============================================
// Cloudinary (if using for file uploads)
// ============================================
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
